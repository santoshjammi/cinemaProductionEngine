{
  "1": {
    "inputs": {
      "unet_name": "flux1-dev-bf16.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader",
    "_meta": {"title": "Load FLUX Diffusion Model (bf16 for MPS)"}
  },
  "2": {
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux",
      "device": "default"
    },
    "class_type": "DualCLIPLoader",
    "_meta": {"title": "Load Dual CLIP (CLIP-L + T5-XXL)"}
  },
  "3": {
    "inputs": {
      "vae_name": "flux-vae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": {"title": "Load FLUX VAE"}
  },
  "4": {
    "inputs": {
      "image": "PLACEHOLDER_CHARACTER_REFERENCE"
    },
    "class_type": "LoadImage",
    "_meta": {"title": "Load Character Reference"}
  },
  "5": {
    "inputs": {
      "clip_vision": ["8", 0],
      "image": ["4", 0]
    },
    "class_type": "CLIPVisionEncode",
    "_meta": {"title": "Encode Character Reference"}
  },
  "6": {
    "inputs": {
      "weight": 0.6,
      "noise": 0.0,
      "start_at": 0.0,
      "end_at": 1.0,
      "unet": ["1", 0],
      "image": ["5", 0]
    },
    "class_type": "IPAdapter",
    "_meta": {"title": "IPAdapter (character consistency)"}
  },
  "7": {
    "inputs": {
      "text": "PLACEHOLDER_PROMPT",
      "clip": ["2", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Text Encode (Positive Prompt)"}
  },
  "8": {
    "inputs": {
      "clip_name": "sigclip_vision_patch14_384.safetensors"
    },
    "class_type": "CLIPVisionLoader",
    "_meta": {"title": "Load CLIP Vision (placeholder)"}
  },
  "9": {
    "inputs": {
      "conditioning": ["7", 0],
      "guidance": 3.5
    },
    "class_type": "FluxGuidance",
    "_meta": {"title": "FLUX Guidance (positive)"}
  },
  "10": {
    "inputs": {
      "text": "PLACEHOLDER_NEGATIVE_PROMPT",
      "clip": ["2", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Text Encode (Negative Prompt)"}
  },
  "11": {
    "inputs": {
      "width": 1024,
      "height": 576,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"}
  },
  "12": {
    "inputs": {
      "seed": 42,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["6", 0],
      "positive": ["9", 0],
      "negative": ["10", 0],
      "latent_image": ["11", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (IPAdapter)"}
  },
  "13": {
    "inputs": {
      "samples": ["12", 0],
      "vae": ["3", 0]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "14": {
    "inputs": {
      "filename_prefix": "FluxDev_IPAdapter",
      "images": ["13", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image (IPAdapter)"}
  }
}
